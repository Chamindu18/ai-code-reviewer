# ====================================
# Server Configuration
# ====================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# ====================================
# Database
# ====================================
DATABASE_URL="postgresql://postgres:12345@localhost:5432/code_reviewer?schema=public"

# ====================================
# Redis (Job Queue)
# ====================================
REDIS_URL="redis://localhost:6379"

# ====================================
# GitHub Integration
# ====================================
# Create at: https://github.com/settings/tokens
# Required scopes: repo, write:repo_hook
GITHUB_TOKEN="ghp_your_personal_access_token_here"

# Create webhook secret in GitHub repo settings
# Repo Settings > Webhooks > Secret
GITHUB_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# ====================================
# AI Service (Google Gemini)
# ====================================
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy_your_gemini_key_here"

# ====================================
# API Security
# ====================================
# Generate with: openssl rand -base64 32
API_SECRET="your_32_character_secret_key_for_api_auth"