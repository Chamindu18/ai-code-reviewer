    "db:studio": "prisma studio --schema=src/db/prisma/schema.prisma",
    "db:seed": "tsx scripts/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.js"
  },
